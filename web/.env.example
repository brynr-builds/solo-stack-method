# Solo Stack Method Web App - Environment Variables
# Copy this to .env.local and fill in your values

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your-project-url.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-side only (never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database (required for admin auth)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Admin Auth (required for /admin/* in production)
# Only this email can be admin (single-admin for now)
ADMIN_ALLOWED_EMAIL=brynrgarnett@gmail.com
# One-time secret to claim first admin. Generate: openssl rand -hex 32
ADMIN_SETUP_SECRET=
# WebAuthn: use "localhost" for local dev; your domain for prod
ADMIN_RP_ID=localhost
ADMIN_RP_NAME=Solo Stack Method
# Full origin: http://localhost:3000 (dev) or https://yourdomain.com (prod)
ADMIN_ORIGIN=http://localhost:3000
# Session signing. Generate: openssl rand -hex 32
ADMIN_SESSION_SECRET=
ADMIN_SESSION_TTL_HOURS=8
ADMIN_RATE_LIMIT_PER_MINUTE=20

# Build flow (/build) — connect GitHub + create repo from template.
# See docs/solo-stack/BUILD_FLOW_SETUP.md. Without these, /build shows a "not configured" notice.
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
# Encrypts the user's GitHub token cookie. Generate: openssl rand -hex 32
BUILD_SESSION_SECRET=
# Optional — defaults to brynr-builds/solo-stack-starter
GITHUB_TEMPLATE_REPO=brynr-builds/solo-stack-starter

# Analytics (privacy-friendly; free tiers). No env = no tracking. Pick ONE provider:
#   Umami:      NEXT_PUBLIC_ANALYTICS_SRC=https://cloud.umami.is/script.js  NEXT_PUBLIC_ANALYTICS_ID=<website-id>
#   Plausible:  NEXT_PUBLIC_ANALYTICS_SRC=https://plausible.io/js/script.js  NEXT_PUBLIC_ANALYTICS_DOMAIN=solostackmethod.io
#   Cloudflare: NEXT_PUBLIC_ANALYTICS_SRC=https://static.cloudflareinsights.com/beacon.min.js  NEXT_PUBLIC_ANALYTICS_ID=<token>
NEXT_PUBLIC_ANALYTICS_SRC=
NEXT_PUBLIC_ANALYTICS_ID=
NEXT_PUBLIC_ANALYTICS_DOMAIN=

# Stack Pulse (Phase 2+)
# STACK_PULSE_SECRET=your-pulse-secret

# Stripe (Phase 2+)
# STRIPE_SECRET_KEY=your-stripe-key
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your-publishable-key
