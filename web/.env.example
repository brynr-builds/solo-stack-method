# Solo Stack Method Web App - Environment Variables
# Copy this to .env.local and fill in your values

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your-project-url.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-side only (never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database (required for admin auth)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Admin Auth (required for /admin/* in production)
# Only this email can be admin (single-admin for now)
ADMIN_ALLOWED_EMAIL=brynrgarnett@gmail.com
# One-time secret to claim first admin. Generate: openssl rand -hex 32
ADMIN_SETUP_SECRET=
# WebAuthn: use "localhost" for local dev; your domain for prod
ADMIN_RP_ID=localhost
ADMIN_RP_NAME=Solo Stack Method
# Full origin: http://localhost:3000 (dev) or https://yourdomain.com (prod)
ADMIN_ORIGIN=http://localhost:3000
# Session signing. Generate: openssl rand -hex 32
ADMIN_SESSION_SECRET=
ADMIN_SESSION_TTL_HOURS=8
ADMIN_RATE_LIMIT_PER_MINUTE=20

# Stack Pulse — fully autonomous refresh (configure once, runs forever)
# Generate the secret: openssl rand -hex 32
PULSE_REFRESH_SECRET=your-pulse-refresh-secret

# AI provider keys — used to fetch live model versions from provider APIs.
# Add any you have; missing keys are skipped gracefully (last DB value kept).
ANTHROPIC_API_KEY=your-anthropic-key
OPENAI_API_KEY=your-openai-key
GOOGLE_AI_API_KEY=your-google-ai-key
MISTRAL_API_KEY=your-mistral-key

# GitHub token — optional, increases rate limit from 60 to 5000 req/hr.
# Needed for IDE version tracking (Cursor, Windsurf).
GITHUB_TOKEN=your-github-token

# Stripe (Phase 2+)
# STRIPE_SECRET_KEY=your-stripe-key
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your-publishable-key
